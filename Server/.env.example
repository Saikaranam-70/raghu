# =====================================================
#  .env.example — Copy to .env and fill in values
#  NEVER commit .env to git!
# =====================================================

# ── Google Sheets ─────────────────────────────────
# Path to your downloaded service account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/service_account.json

# Paste your Spreadsheet ID from the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# The exact tab name at the bottom of your sheet
SHEET_NAME=Sheet1

# ── API Key ───────────────────────────────────────
# Students use this key to access the API
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# You can add multiple keys separated by commas
API_KEYS=generate_a_random_key_here,optional_second_key

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# ── Cache ─────────────────────────────────────────
# How long (seconds) to cache Google Sheets data
CACHE_TTL_SECONDS=300

# ── App ───────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
